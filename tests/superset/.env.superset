# Data Formulator env overrides for Superset plugin testing.
# Source this file or pass it to the start script.

# -- Superset plugin config --
PLG_SUPERSET_URL=http://localhost:8088

# -- Optional: credential vault (Fernet-encrypted SQLite) --
# CREDENTIAL_VAULT=local

# -- Optional: SSO login URL (enabled by default for local test Superset) --
PLG_SUPERSET_SSO_LOGIN_URL=http://localhost:8088/df-sso-bridge/
